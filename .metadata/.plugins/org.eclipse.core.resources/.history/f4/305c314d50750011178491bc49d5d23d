/**
  * @brief  Initialize CMSIS-DSP instances and precompute Hann window.
  */
void DSP_Init(void)
{
    arm_rfft_fast_init_f32(&S, FFT_SIZE);

    /* Precompute Hann Window to save CPU cycles during runtime */
    for (uint16_t i = 0; i < FFT_SIZE; i++) {
        hann_window[i] = 0.5f * (1.0f - cosf(2.0f * PI * i / (FFT_SIZE - 1)));
    }
}

/**
  * @brief  Enqueues a complete binary packet into the TX queue.
  */
static void Packet_Queue_Enqueue(const void *src)
{
    if (queue_count >= TX_QUEUE_DEPTH)
    {
        queue_overflow_count++; /* Drop frame if queue is full (Non-blocking requirement) */
        return;
    }

    memcpy(&tx_queue[queue_tail][0], src, PACKET_SIZE_BYTES);
    queue_tail = (queue_tail + 1) & TX_QUEUE_INDEX_MASK;
    queue_count++;
}

/**
  * @brief  Mode 1: Prepare and enqueue Raw ADC Packet.
  */
void SendRawPacket(void)
{
    static RawPacket_t pkt;
    pkt.header = RAW_HEADER;
    pkt.frame_id = frame_id++;
    memcpy(pkt.samples, adc_buffer, FFT_SIZE * sizeof(uint16_t));
    Packet_Queue_Enqueue(&pkt);
}

/**
  * @brief  Mode 2: Execute DSP pipeline and enqueue FFT Packet.
  */
void DSP_ProcessFrame(void)
{
    float32_t mean;

    /* 1. Compute DC offset */
    arm_mean_f32(fft_input, FFT_SIZE, &mean);

    /* 2. Remove DC offset (In-place) */
    arm_offset_f32(fft_input, -mean, fft_input, FFT_SIZE);

    /* 3. Apply Hann Window (In-place) */
    arm_mult_f32(fft_input, hann_window, fft_input, FFT_SIZE);

    /* 4. CMSIS Real FFT */
    arm_rfft_fast_f32(&S, fft_input, fft_output, 0);

    /* 5. Magnitude calculation */
    arm_cmplx_mag_f32(fft_output, fft_magnitude, FFT_SIZE / 2);

    /* Optional: Scale magnitude for better visualization */
    arm_scale_f32(fft_magnitude, 2.0f / FFT_SIZE, fft_magnitude, FFT_SIZE / 2);

    SendFFTPacket();
}

/**
  * @brief  Helper to enqueue the FFT packet.
  */
void SendFFTPacket(void)
{
    static FFTPacket_t pkt;
    pkt.header = FFT_HEADER;
    pkt.frame_id = frame_id++;
    memcpy(pkt.magnitude, fft_magnitude, (FFT_SIZE / 2) * sizeof(float32_t));
    Packet_Queue_Enqueue(&pkt);
}

/**
  * @brief  Runtime mode switcher. Can be called by future UART/USB commands.
  */
void SetOutputMode(OutputMode_t mode)
{
    output_mode = mode;
}

/**
  * @brief  ADC Full Conversion Complete Callback.
  *         Processes the entire 1024-sample buffer.
  */
void HAL_ADC_ConvCpltCallback(ADC_HandleTypeDef *hadc)
{
    if (hadc->Instance == ADC1)
    {
        /* Invalidate D-Cache for the entire buffer */
        SCB_InvalidateDCache_by_Addr((uint32_t *)&adc_buffer[0], ADC_BUFFER_SIZE * sizeof(uint16_t));

        /* Prepare float input for DSP (Required for both modes to keep logic unified,
           though Raw mode doesn't strictly need it, it's fast enough) */
        for (uint16_t i = 0; i < FFT_SIZE; i++) {
            fft_input[i] = (float32_t)adc_buffer[i];
        }

        /* Modular switching mechanism */
        switch (output_mode)
        {
            case OUTPUT_RAW_ADC:
                SendRawPacket();
                break;

            case OUTPUT_FFT:
                DSP_ProcessFrame();
                break;

            default:
                break;
        }
    }
}

/**
  * @brief  UART TX Complete Callback.
  */
void HAL_UART_TxCpltCallback(UART_HandleTypeDef *huart)
{
    if (huart->Instance == USART3)
    {
        queue_head = (queue_head + 1) & TX_QUEUE_INDEX_MASK;
        queue_count--;
        uart_tx_busy = 0;
    }
}

/**
  * @brief  UART Error Callback.
  */
void HAL_UART_ErrorCallback(UART_HandleTypeDef *huart)
{
    if (huart->Instance == USART3)
    {
        if (uart_tx_busy)
        {
            queue_head = (queue_head + 1) & TX_QUEUE_INDEX_MASK;
            if (queue_count > 0) queue_count--;
            uart_tx_busy = 0;
        }
        __HAL_UART_CLEAR_PEFLAG(huart);
    }
}

/**
  * @brief  Services the TX queue via non-blocking UART DMA.
  */
static void UART_Queue_Service(void)
{
    if ((uart_tx_busy == 0) && (queue_count > 0))
    {
        uart_tx_busy = 1;

        /* Clean D-Cache before UART DMA reads the packet */
        SCB_CleanDCache_by_Addr((uint32_t *)&tx_queue[queue_head][0], PACKET_SIZE_BYTES);

        if (HAL_UART_Transmit_DMA(&huart3,
                                   (uint8_t *)&tx_queue[queue_head][0],
                                   PACKET_SIZE_BYTES) != HAL_OK)
        {
            uart_tx_busy = 0;
        }
    }
}
