/**
  * @brief  Enqueue one ready ADC half-buffer into the software TX ring
  *         buffer. Called from ADC ISR context (half/complete callbacks).
  * @param  src Pointer to the first sample of the half-buffer to enqueue
  *             (either &adc_buffer[0] or &adc_buffer[ADC_HALF_BUFFER_SIZE]).
  * @note   Kept intentionally minimal for ISR safety (requirement #15):
  *         a single bounded memcpy plus index bookkeeping, no UART calls,
  *         no blocking, no loops over unbounded data.
  *         If the queue is full, the new half-buffer is dropped and
  *         queue_overflow_count is incremented for diagnostics rather
  *         than corrupting an in-use slot or blocking the ISR.
  */
static void ADC_Queue_Enqueue(const uint16_t *src)
{
  if (queue_count >= TX_QUEUE_DEPTH)
  {
    /* Queue full: UART can't keep up on average. Drop this half-buffer
       (oldest queued data is preserved/still in flight) and record it. */
    queue_overflow_count++;
    return;
  }

  /* Fast bounded copy: 512 * 2 = 1024 bytes, fixed size, no loops over
     variable-length data -> safe and fast in interrupt context. */
  memcpy(&tx_queue[queue_tail][0], src, ADC_HALF_BUFFER_SIZE * sizeof(uint16_t));

  queue_tail = (queue_tail + 1) & TX_QUEUE_INDEX_MASK;
  queue_count++;
}

/**
  * @brief  ADC conversion half-complete callback.
  *         DMA has just finished filling adc_buffer[0 .. 511]; DMA is now
  *         writing into the second half, so the first half is safe to copy.
  * @note   ISR context - body is just one bounded memcpy via the enqueue
  *         helper above. No UART/HAL transmit calls are made here.
  */
void HAL_ADC_ConvHalfCpltCallback(ADC_HandleTypeDef *hadc)
{  HAL_GPIO_TogglePin(GPIOB, GPIO_PIN_0);   // or use LD1 if configured
  if (hadc->Instance == ADC1)
  {
    ADC_Queue_Enqueue(&adc_buffer[0]);
  }
}

/**
  * @brief  ADC conversion complete callback.
  *         DMA has just finished filling adc_buffer[512 .. 1023] and wraps
  *         circularly back to index 0, so the second half is safe to copy.
  * @note   ISR context - same minimal-work pattern as the half-complete
  *         callback above.
  */
void HAL_ADC_ConvCpltCallback(ADC_HandleTypeDef *hadc)
{ printf("Full\r\n");
  if (hadc->Instance == ADC1)
  {
    ADC_Queue_Enqueue(&adc_buffer[ADC_HALF_BUFFER_SIZE]);
  }
}

/**
  * @brief  UART DMA transmit-complete callback.
  *         Retires the slot that was just sent and clears the busy flag so
  *         the main loop can launch the next queued transmission.
  * @note   ISR context - O(1) index update only.
  */
void HAL_UART_TxCpltCallback(UART_HandleTypeDef *huart)
{
  if (huart->Instance == USART3)
  {
    queue_head = (queue_head + 1) & TX_QUEUE_INDEX_MASK;
    queue_count--;
    uart_tx_busy = 0;
  }
}

/**
  * @brief  UART error callback.
  *         Ensures a transmission error (e.g. framing/overrun on the line,
  *         or a DMA transfer error) can never permanently latch
  *         uart_tx_busy and silently stall all further transmission.
  *         The current (failed) slot is retired the same way a completed
  *         one would be, since its data is gone either way; the queue
  *         simply moves on to the next slot.
  * @note   ISR context - minimal recovery only.
  */
void HAL_UART_ErrorCallback(UART_HandleTypeDef *huart)
{
  if (huart->Instance == USART3)
  {
    if (uart_tx_busy)
    {
      queue_head = (queue_head + 1) & TX_QUEUE_INDEX_MASK;
      if (queue_count > 0)
      {
        queue_count--;
      }
      uart_tx_busy = 0;
    }
    /* Clear error state and make sure the DMA stream is ready to accept
       a new transfer request on the next Transmit_DMA call. */
    __HAL_UART_CLEAR_PEFLAG(huart);
  }
}

/**
  * @brief  Services the TX queue from the main loop: if UART is idle and
  *         at least one half-buffer is queued, launches a single
  *         non-blocking UART DMA transmission for the oldest queued slot.
  * @note   Called repeatedly from the main while(1) loop (requirement #16:
  *         heavy/non-deterministic-latency work lives here, not in ISRs).
  *         Sends exactly ADC_HALF_BUFFER_SIZE * 2 = 1024 raw bytes,
  *         native little-endian uint16_t layout - no ASCII, no headers,
  *         no delimiters, fully compatible with future FFT processing
  *         on the PC side.
  */
static void UART_Queue_Service(void)
{
  if ((uart_tx_busy == 0) && (queue_count > 0))
  {
    uart_tx_busy = 1;
    if (HAL_UART_Transmit_DMA(&huart3,
                               (uint8_t *)&tx_queue[queue_head][0],
                               ADC_HALF_BUFFER_SIZE * sizeof(uint16_t)) != HAL_OK)
    {
      /* Could not even start the DMA transfer (e.g. UART busy at HAL
         level from some other path). Don't get stuck: release the busy
         flag so this slot is retried on the next loop iteration instead
         of stalling the whole queue. The slot is NOT retired here since
         it was never actually sent. */
      uart_tx_busy = 0;
    }
  }
}

