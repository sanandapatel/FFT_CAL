  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_DMA_Init();
  MX_ETH_Init();
  MX_USART3_UART_Init();
  MX_USB_OTG_FS_PCD_Init();
  MX_ADC1_Init();
  MX_TIM2_Init();
  /* USER CODE BEGIN 2 */

  /* Start ADC1 in DMA circular mode FIRST, arming the ADC/DMA chain so it
     is ready to accept conversion results before any trigger can occur.
     DMA2_Stream0 will continuously write samples into adc_buffer[] and
     wrap automatically (Circular Mode, configured by CubeMX). */
  if (HAL_ADC_Start_DMA(&hadc1, (uint32_t *)adc_buffer, ADC_BUFFER_SIZE) != HAL_OK)
  {
    Error_Handler();
  }

  /* Start TIM2 AFTER the ADC/DMA chain is armed, so no TRGO edge can be
     missed. TIM2 TRGO (update event) triggers one regular ADC conversion
     per pulse; timer prescaler/period are unchanged from the existing
     CubeMX configuration, preserving the ~42.67 kSPS sampling rate exactly
     as required. */
  if (HAL_TIM_Base_Start(&htim2) != HAL_OK)
  {
    Error_Handler();
  }

  /* USER CODE END 2 */
  char msg[32];
  snprintf(msg, sizeof(msg), "%u\r\n", adc_buffer[0]);
  HAL_UART_Transmit(&huart3, (uint8_t *)msg, strlen(msg), HAL_MAX_DELAY);
  HAL_Delay(100);
  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
    /* All real work (UART queue draining) happens here in the main loop,
       outside of interrupt context, per requirement #16. This call is
       cheap and non-blocking: it either launches one new non-blocking
       DMA transmission or does nothing if UART is already busy / queue
       is empty, so the loop spins fast and never delays servicing of
       the next ADC callback. */
    UART_Queue_Service();

    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */

    /* Acquisition (ADC + DMA2_Stream0, hardware-triggered by TIM2) and
       transmission (USART3 DMA, non-blocking, ring-buffered) both run
       autonomously in the background. DMA is never stopped, so ADC
       acquisition continues forever, satisfying requirements #8/#9.
       queue_overflow_count can be inspected in a debugger to confirm
       zero sample loss during bring-up/validation. */
  }
  /* USER CODE END 3 */
}

