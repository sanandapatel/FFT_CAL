/* Total samples in the circular ADC/DMA buffer (2 halves of 512 samples).
   At ~42.67 kSPS this represents ~24 ms of audio and produces a
   half-complete / complete callback roughly every ~12 ms. */
#define ADC_BUFFER_SIZE        1024
#define ADC_HALF_BUFFER_SIZE   (ADC_BUFFER_SIZE / 2)   /* 512 samples = 1024 bytes per half */

/* Depth of the software transmission queue (ring buffer of half-buffers).
   Each slot holds one ADC half-buffer (512 samples / 1024 bytes).
   Depth of 8 gives ~8 * 12 ms = ~96 ms of buffering headroom to absorb
   UART/DMA latency jitter without losing samples, at a RAM cost of
   8 * 1024 bytes = 8 KB - negligible on the F767's 512 KB SRAM.
   Must be a power of two so index wraparound can use a simple mask. */
#define TX_QUEUE_DEPTH          8
#define TX_QUEUE_INDEX_MASK    (TX_QUEUE_DEPTH - 1)

