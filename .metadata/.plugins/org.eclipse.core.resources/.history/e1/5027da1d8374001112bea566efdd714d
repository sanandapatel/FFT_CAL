/* Circular ADC sample buffer, continuously filled by ADC1 via DMA2_Stream0
   in circular mode. Hardware-triggered by TIM2 TRGO; never stopped. */
uint16_t adc_buffer[ADC_BUFFER_SIZE];

/* ---- Software transmission ring buffer (queue of half-buffers) ----
   Decouples ADC acquisition cadence from UART transmission cadence so
   that a momentarily busy/slow UART link never blocks or stalls the
   ADC DMA pipeline, and no samples are silently dropped under normal
   (non-overflow) operating conditions. */
static uint16_t tx_queue[TX_QUEUE_DEPTH][ADC_HALF_BUFFER_SIZE];

/* Queue indices. Each is touched by exactly one producer/consumer context,
   so plain volatile access is safe on this single-core Cortex-M part
   without additional locking:
     - queue_tail / queue_count (increment) : written only by ADC ISR callbacks
     - queue_head / queue_count (decrement) : written only by UART TxCplt ISR
     - both                                  : read only by the main loop
*/
static volatile uint16_t queue_head  = 0;  /* next slot to transmit            */
static volatile uint16_t queue_tail  = 0;  /* next free slot to fill           */
static volatile uint16_t queue_count = 0;  /* number of slots currently queued */

/* Diagnostic counter: increments if the queue is ever completely full when
   a new half-buffer becomes ready (i.e. average UART throughput is too low
   for the configured baud rate / sample rate). In normal operation with the
   baud rate set below this should remain 0. Exposed so it can be inspected
   in a debugger or optionally reported over a side channel. */
static volatile uint32_t queue_overflow_count = 0;

/* True while a USART3 DMA transmission is in flight. Cleared by
   HAL_UART_TxCpltCallback (success) or HAL_UART_ErrorCallback (failure),
   so it can never get permanently stuck on a transmission error. */
static volatile uint8_t uart_tx_busy = 0;

/* USER CODE END PV */

