/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{
  /* Configure MPU to protect buffer regions against Cache discrepancies */
  MPU_Config();

  /* Enable CPU L1-Cache engines */
  SCB_EnableICache();
  SCB_EnableDCache();

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* Configure the system clock */
  SystemClock_Config();

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_DMA_Init(); // Must initialize DMA prior to peripheral setup mapping
  MX_ETH_Init();
  MX_USART3_UART_Init();
  MX_USB_OTG_FS_PCD_Init();
  MX_ADC1_Init();
  MX_TIM2_Init();

  /* USER CODE BEGIN 2 */
  /* Target execution pipeline setup: Arm DMA pipeline first, then release hardware timer.
     Starting ADC DMA before TIM2 ensures no trigger events are missed during startup. */
  if (HAL_ADC_Start_DMA(&hadc1, (uint32_t *)adc_buffer, ADC_BUFFER_SIZE) != HAL_OK)
  {
    Error_Handler();
  }

  if (HAL_TIM_Base_Start(&htim2) != HAL_OK)
  {
    Error_Handler();
  }
  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
    // Continuously check if there is data in the queue ready to be sent over UART
    UART_Queue_Service();
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
  }
  /* USER CODE END 3 */
}

