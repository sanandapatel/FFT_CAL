/**
  * @brief  Enqueues a half-buffer of ADC data into the TX queue.
  * @param  src: Pointer to the source ADC data (either first or second half).
  */
static void ADC_Queue_Enqueue(const uint16_t *src)
{
  if (queue_count >= TX_QUEUE_DEPTH)
  {
    queue_overflow_count++; // Track overflows for debugging
    return;
  }

  // Copy raw binary data into the transmission queue
  memcpy(&tx_queue[queue_tail][0], src, ADC_HALF_BUFFER_SIZE * sizeof(uint16_t));
  queue_tail = (queue_tail + 1) & TX_QUEUE_INDEX_MASK;
  queue_count++;
}

/**
  * @brief  ADC Half Conversion Complete Callback.
  *         Triggered when the first 512 samples are acquired.
  */
void HAL_ADC_ConvHalfCpltCallback(ADC_HandleTypeDef *hadc)
{
  if (hadc->Instance == ADC1)
  {
    /* CRITICAL: Invalidate D-Cache before CPU reads data written by ADC DMA.
       This ensures the CPU reads the actual physical RAM values, not stale cached data. */
    SCB_InvalidateDCache_by_Addr((uint32_t *)&adc_buffer[0], ADC_HALF_BUFFER_SIZE * sizeof(uint16_t));

    HAL_GPIO_TogglePin(GPIOB, GPIO_PIN_0); // Toggle LD1 to track performance visually
    ADC_Queue_Enqueue(&adc_buffer[0]);
  }
}

/**
  * @brief  ADC Full Conversion Complete Callback.
  *         Triggered when the second 512 samples are acquired.
  */
void HAL_ADC_ConvCpltCallback(ADC_HandleTypeDef *hadc)
{
  if (hadc->Instance == ADC1)
  {
    /* CRITICAL: Invalidate D-Cache for the second half of the buffer */
    SCB_InvalidateDCache_by_Addr((uint32_t *)&adc_buffer[ADC_HALF_BUFFER_SIZE], ADC_HALF_BUFFER_SIZE * sizeof(uint16_t));

    ADC_Queue_Enqueue(&adc_buffer[ADC_HALF_BUFFER_SIZE]);
  }
}

/**
  * @brief  UART TX Complete Callback.
  *         Resets the busy flag and advances the queue head.
  */
void HAL_UART_TxCpltCallback(UART_HandleTypeDef *huart)
{
  if (huart->Instance == USART3)
  {
    queue_head = (queue_head + 1) & TX_QUEUE_INDEX_MASK;
    queue_count--;
    uart_tx_busy = 0;
  }
}

/**
  * @brief  UART Error Callback.
  *         Handles transmission errors (e.g., overrun) to prevent the queue from stalling.
  */
void HAL_UART_ErrorCallback(UART_HandleTypeDef *huart)
{
  if (huart->Instance == USART3)
  {
    if (uart_tx_busy)
    {
      queue_head = (queue_head + 1) & TX_QUEUE_INDEX_MASK;
      if (queue_count > 0)
      {
        queue_count--;
      }
      uart_tx_busy = 0;
    }
    __HAL_UART_CLEAR_PEFLAG(huart);
  }
}

/**
  * @brief  Services the TX queue by initiating non-blocking UART DMA transfers.
  */
static void UART_Queue_Service(void)
{
  if ((uart_tx_busy == 0) && (queue_count > 0))
  {
    uart_tx_busy = 1;

    /* CRITICAL: Clean D-Cache before UART DMA reads data written by the CPU.
       This pushes the CPU's modified data from the cache down to physical RAM
       so the UART DMA peripheral can read the correct raw binary bytes. */
    SCB_CleanDCache_by_Addr((uint32_t *)&tx_queue[queue_head][0], ADC_HALF_BUFFER_SIZE * sizeof(uint16_t));

    // Transmit exactly 1024 bytes (512 samples * 2 bytes/sample) of RAW binary data
    if (HAL_UART_Transmit_DMA(&huart3,
                               (uint8_t *)&tx_queue[queue_head][0],
                               ADC_HALF_BUFFER_SIZE * sizeof(uint16_t)) != HAL_OK)
    {
      uart_tx_busy = 0; // Release flag if DMA initiation fails
    }
  }
}
